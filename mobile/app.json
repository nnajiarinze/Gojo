{
  "expo": {
    "name": "Gojo",
    "slug": "gojo",
    "version": "1.0.0",
    "scheme": "gojo",
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Gojo needs camera access to scan receipts."
        }
      ],
      "expo-router",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.anonymous.gojo"
    },
    "ios": {
      "bundleIdentifier": "com.anonymous.gojo"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "888e478c-901f-4f6d-a4e9-b70c6c75c4ca"
      }
    }
  }
}
